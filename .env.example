# ─────────────────────────────────────────────────────────────
# Vite environment variables for the Voicedots website
# Copy to .env (local) or set these in Vercel → Project Settings →
# Environment Variables. All must be prefixed with VITE_ to be exposed
# to the browser build.
# ─────────────────────────────────────────────────────────────

# LiveKit media server WebSocket URL.
# OPTIONAL for the demo — the ws_url normally comes from the token service
# response; this is only a fallback.
VITE_LIVEKIT_URL=wss://livekit.voicedots.io

# Sarvam low-latency pipeline WS endpoint (Voicedots demo bot only).
# Defaults to wss://voice.voicedots.io/ws if unset.
VITE_SARVAM_WS_URL=wss://voice.voicedots.io/ws

# Public website backend API base (used by Blogs list/detail and Contact form).
# e.g. https://api.voicedots.io  (no trailing slash)
VITE_API_URL=

# Backend API base for support ticket submission (TicketModal).
VITE_BACKEND_API_URL=

# Supabase — currently NOT used by the app. Leave blank unless you wire it up.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
